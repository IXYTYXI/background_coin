# 飞书企业自建应用 App ID / App Secret。
# 新应用建议使用“光年币助手”。
# App 需要配置 OAuth 重定向 URL，例如：
# https://guangnianbi.yc345.tv/oauth/callback
FEISHU_APP_ID=cli_aaba740b6939dbb7
FEISHU_APP_SECRET=replace_with_your_app_secret

# 飞书开放平台回调安全配置。如果后台未开启回调验签/加密，可留空。
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# 多维表格配置：应用 token、领取流水表、账户表、支取表、前端白名单表。
BASE_TOKEN=KrVRbjTKOatunlslgHlcdPyindc
LEDGER_TABLE=tbl88pkryfLsRNNk
ACCOUNT_TABLE=tblcvlBAmioZD4CJ
WITHDRAW_TABLE=tblP1pNflMJGHDgf
WHITELIST_TABLE=tbleU3I3ejRn3sTj
WHITELIST_PERSON_FIELD=fldqSinMmy

# 管理员飞书 open_id。当前管理员：芮婷。
ADMIN_USER_ID=ou_0666dc75244dd56bbbad486f995caf1f

# 支取表字段配置。默认值对应“光年币支取表”，通常不需要改。
WITHDRAW_SERIAL_FIELD=fldNvlM3Q8
WITHDRAW_PERSON_FIELD=fldMh5eZJx
WITHDRAW_ACCOUNT_FIELD=fldMBp5NJI
WITHDRAW_AMOUNT_FIELD=flddN5H2om
WITHDRAW_BEFORE_BALANCE_FIELD=fldYaKq6dU
WITHDRAW_AFTER_BALANCE_FIELD=fldHoUYMSx
WITHDRAW_TIME_FIELD=fld80lEU6y

# 支取表轮询用于捕捉管理员在多维表格里直接新增/修改支取记录。
WITHDRAW_POLL_ENABLED=true
WITHDRAW_POLL_INTERVAL_MS=60000
WITHDRAW_WEBHOOK_TOKEN=

# 生产环境对外访问地址。Nginx 反代和飞书 OAuth 回调必须与它一致。
PUBLIC_ORIGIN=https://guangnianbi.yc345.tv

# 签名 Cookie 密钥。请使用 32 位以上随机字符串，不要使用示例值。
SESSION_SECRET=replace_with_32_plus_random_chars

# Node 后端监听端口，Nginx 反向代理到此端口。
PORT=19001
